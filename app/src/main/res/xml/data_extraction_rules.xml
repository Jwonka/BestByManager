<?xml version="1.0" encoding="utf-8"?><!--
   Sample data extraction rules file; uncomment and customize as necessary.
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
   for details.
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Keep business data -->
        <include domain="database" path="bestbymanager.db" />
        <include domain="database" path="bestbymanager.db-wal" />
        <include domain="database" path="bestbymanager.db-shm" />

        <!-- Keep preferences -->
        <include domain="sharedpref" path="." />

        <!-- Exclude session state -->
        <exclude domain="sharedpref" path="bestby_state.xml" />
    </cloud-backup>

    <device-transfer>
        <!-- Same policy for device-to-device restore -->
        <include domain="database" path="bestbymanager.db" />
        <include domain="database" path="bestbymanager.db" />
        <include domain="database" path="bestbymanager.db" />

        <include domain="sharedpref" path="." />

        <exclude domain="sharedpref" path="bestby_state.xml" />
    </device-transfer>
</data-extraction-rules>