<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mint_green"
    tools:context=".UI.activities.InstructionsActivity">

    <TextView
        android:id="@+id/instructions_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/instructions"
        android:textColor="@color/black"
        android:textSize="32sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="@color/gray"
        android:padding="@dimen/padding_l"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/instructions_card"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="@dimen/spacing_s"
        app:cardCornerRadius="0dp"
        app:cardBackgroundColor="@color/sky_blue"
        app:strokeColor="@color/black"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/instructions_title"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="@dimen/padding_m">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/instructions_setup_title" android:textStyle="bold" android:textColor="@color/black" android:textSize="20sp" android:gravity="center" android:layout_marginBottom="8dp"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/instructions_setup_body" android:textColor="@color/black" android:textSize="18sp" android:lineSpacingExtra="6dp" android:paddingStart="@dimen/spacing_s" android:paddingEnd="@dimen/spacing_s" android:layout_marginBottom="16dp"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/instructions_employees_title" android:textStyle="bold" android:textColor="@color/black" android:textSize="20sp" android:gravity="center" android:layout_marginBottom="8dp"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/instructions_employees_body" android:textColor="@color/black" android:textSize="18sp" android:lineSpacingExtra="6dp" android:paddingStart="@dimen/spacing_s" android:paddingEnd="@dimen/spacing_s" android:layout_marginBottom="16dp"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/instructions_products_title" android:textStyle="bold" android:textColor="@color/black" android:textSize="20sp" android:gravity="center" android:layout_marginBottom="8dp"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/instructions_products_body" android:textColor="@color/black" android:textSize="18sp" android:lineSpacingExtra="6dp" android:paddingStart="@dimen/spacing_s" android:paddingEnd="@dimen/spacing_s" android:layout_marginBottom="16dp"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/instructions_expiration_title" android:textStyle="bold" android:textColor="@color/black" android:textSize="20sp" android:gravity="center" android:layout_marginBottom="8dp"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/instructions_expiration_body" android:textColor="@color/black" android:textSize="18sp" android:lineSpacingExtra="6dp" android:paddingStart="@dimen/spacing_s" android:paddingEnd="@dimen/spacing_s" android:layout_marginBottom="16dp"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/instructions_discard_title" android:textStyle="bold" android:textColor="@color/black" android:textSize="20sp" android:gravity="center" android:layout_marginBottom="8dp"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/instructions_discard_body" android:textColor="@color/black" android:textSize="18sp" android:lineSpacingExtra="6dp" android:paddingStart="@dimen/spacing_s" android:paddingEnd="@dimen/spacing_s" android:layout_marginBottom="16dp"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/instructions_pin_title" android:textStyle="bold" android:textColor="@color/black" android:textSize="20sp" android:gravity="center" android:layout_marginBottom="8dp"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/instructions_pin_body" android:textColor="@color/black" android:textSize="18sp" android:lineSpacingExtra="6dp" android:paddingStart="@dimen/spacing_s" android:paddingEnd="@dimen/spacing_s" android:layout_marginBottom="16dp"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/instructions_ownership_title" android:textStyle="bold" android:textColor="@color/black" android:textSize="20sp" android:gravity="center" android:layout_marginBottom="8dp"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/instructions_ownership_body" android:textColor="@color/black" android:textSize="16sp" android:lineSpacingExtra="4dp" android:paddingStart="@dimen/spacing_s" android:paddingEnd="@dimen/spacing_s" android:layout_marginBottom="16dp"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/instructions_reports_title" android:textStyle="bold" android:textColor="@color/black" android:textSize="20sp" android:gravity="center" android:layout_marginBottom="8dp"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/instructions_reports_body" android:textColor="@color/black" android:textSize="18sp" android:lineSpacingExtra="6dp" android:paddingStart="@dimen/spacing_s" android:paddingEnd="@dimen/spacing_s" android:layout_marginBottom="16dp"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/instructions_faq_label" android:textColor="@color/black" android:textSize="18sp" android:gravity="center" android:layout_marginBottom="4dp"/>
                <TextView android:id="@+id/faq_link" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/instructions_faq_link" android:textColor="@color/black" android:textSize="18sp" android:gravity="center" android:layout_marginBottom="@dimen/spacing_l"/>

            </LinearLayout>
        </ScrollView>
    </com.google.android.material.card.MaterialCardView>
</androidx.constraintlayout.widget.ConstraintLayout>